CONFIG_EXAMPLE_ETH_GATEWAY_DHCP_ENABLE_DNS=y
CONFIG_EXAMPLE_ETH_GATEWAY_DHCP_DNS_MAIN="192.168.5.1"
CONFIG_EXAMPLE_ETH_GATEWAY_DHCP_DNS_BACKUP="8.8.8.8"
